# 백엔드 origin (Vite dev proxy target · 프로덕션 빌드 axios baseURL)
# 로컬: http://localhost:8081 · 운영: https://api.marketlens.site (끝에 /api 없음)
VITE_API_URL=http://localhost:8081

# 목 데이터: true | false | (비움=개발에서는 목, 프로덕션 빌드에서는 API)
VITE_USE_MOCK_DATA=false

# 텔레그램 봇 username (@ 제외, 기본값 marketlens_noti_bot)
VITE_TELEGRAM_BOT_USERNAME=marketlens_noti_bot
